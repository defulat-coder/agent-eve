{
  "name": "@agent-template/agent-claude",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "claude:eval": "vitest run evals",
    "claude:eval:list": "vitest list evals",
    "claude:eval:live": "CLAUDE_AGENT_LIVE_EVAL=1 vitest run evals",
    "lint": "eslint src evals",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": ">=0.3.193 <1.0.0",
    "@agent-template/logger": "workspace:*",
    "@agent-template/shared": "workspace:*",
    "ioredis": "^5.11.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
